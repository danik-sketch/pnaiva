-- Добавляем пользователя
INSERT INTO users (username, email, password)
SELECT 'ivan_developer', 'ivan@example.com', 'password123'
WHERE NOT EXISTS (SELECT 1 FROM users WHERE username = 'ivan_developer');

-- Добавляем проект
INSERT INTO projects (name, user_id)
SELECT 'Учеба БГУИР', id FROM users WHERE username = 'ivan_developer'
                                      AND NOT EXISTS (SELECT 1 FROM projects WHERE name = 'Учеба БГУИР');

-- Добавляем задачу (с защитой от дублей и множественных строк)
INSERT INTO tasks (title, description, due_date, completed, project_id)
SELECT 'Сдать лабу по PNAIVA', 'Проверить работу Spring Data JPA', '2026-03-10 10:00:00', false, id
FROM projects
WHERE name = 'Учеба БГУИР'
  AND NOT EXISTS (SELECT 1 FROM tasks WHERE title = 'Сдать лабу по PNAIVA')
LIMIT 1;